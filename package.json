{
  "name": "relationship-exploration-map",
  "version": "1.0.0",
  "private": true,
  "description": "Mapa relacional interactivo con backend Node y frontend estatico",
  "main": "src/server/index.js",
  "scripts": {
    "start": "APP_PORT=${APP_PORT:-8080} node src/server/index.js",
    "dev": "APP_PORT=${APP_PORT:-8080} node src/server/index.js",
    "test": "node --test",
    "smoke": "node scripts/smoke.js",
    "local:stack:up": "docker compose -f docker-compose.local.yml up -d --build",
    "local:stack:down": "docker compose -f docker-compose.local.yml down",
    "local:stack:logs": "docker compose -f docker-compose.local.yml logs -f",
    "local:check": "node scripts/local-check.js",
    "local:stack:check": "node scripts/local-check.js --port 80"
  },
  "engines": {
    "node": ">=18"
  }
}
